{
  "name": "g2-vision-voice-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Even G2 visual and voice assistant using phone camera, G2 display/input, and MiniMax runtime adapters.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:plugin": "npm --workspace apps/evenhub-plugin run dev",
    "dev:api": "npm --workspace services/api-server run dev",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "pack:g2": "npm --workspace apps/evenhub-plugin run pack",
    "test:real": "node scripts/real-integration-smoke.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
