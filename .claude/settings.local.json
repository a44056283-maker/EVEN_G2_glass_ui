{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(npm run pack:g2)",
      "Bash(rg:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(shasum -a 256:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(sed:*)"
    ],
    "ask": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(npm install:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(open:*)"
    ]
  }
}